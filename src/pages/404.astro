---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSectionData, isSectionEnabled } from '../lib/manifest-loader';

const seoData = getSectionData('seo');
const errorData = getSectionData('error-page');
---

<BaseLayout title={`${errorData.errorCode} — ${errorData.errorTitle}`} seo={seoData}>
  <section class="min-h-screen flex items-center justify-center bg-background" data-dr-section="error-page">
    <div class="text-center px-8">
      <p class="text-[10px] tracking-[0.5em] uppercase text-gold mb-6 font-sans">Error</p>
      <h1
        class="font-serif text-8xl md:text-9xl text-primary font-light mb-4 leading-none"
        data-dr-field="errorCode"
        data-dr-style="errorCode"
      >
        {errorData.errorCode}
      </h1>
      <div class="w-10 h-[1px] bg-gold mx-auto mb-4"></div>
      <h2
        class="font-serif text-2xl text-primary font-light mb-3"
        data-dr-field="errorTitle"
        data-dr-style="errorTitle"
      >
        {errorData.errorTitle}
      </h2>
      <p
        class="text-muted text-sm mb-12 tracking-wide"
        data-dr-field="errorMessage"
        data-dr-style="errorMessage"
      >
        {errorData.errorMessage}
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-3 border border-border text-muted text-[11px] tracking-[0.3em] uppercase px-8 py-4 hover:border-gold hover:text-gold transition-all duration-300 font-sans"
      >
        <span data-dr-field="returnHomeText">{errorData.returnHomeText}</span>
      </a>
    </div>
  </section>
</BaseLayout>
