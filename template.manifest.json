{
  "templateId": "noir-luxury",
  "version": "1.0.0",
  "assetStorage": {
    "type": "r2",
    "bucket": "template-assets",
    "prefix": "templates/noir-luxury"
  },
  "collections": [],
  "pages": [
    {
      "id": "home",
      "path": "/",
      "name": "Home",
      "required": true,
      "sections": [
        "hero",
        "tour360",
        "amenities",
        "price-unlock",
        "testimonials"
      ]
    },
    {
      "id": "404",
      "path": "/404",
      "name": "404 Error",
      "required": true,
      "sections": [
        "error-page"
      ]
    }
  ],
  "globalSections": [
    "navigation",
    "footer",
    "seo"
  ],
  "sections": [
    {
      "id": "navigation",
      "name": "Navigation Bar",
      "description": "Top navigation with logo and links.",
      "required": true,
      "imageSlots": [
        "logoImageUrl"
      ],
      "schema": {
        "type": "object",
        "required": [
          "logo",
          "links"
        ],
        "properties": {
          "logoText": {
            "type": "string",
            "uiLabel": "Logo Text"
          },
          "logoImageUrl": {
            "type": "string",
            "uiLabel": "Logo Image",
            "uiWidget": "imageUpload"
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string",
                  "uiLabel": "Link Label"
                },
                "href": {
                  "type": "string",
                  "uiLabel": "Link URL",
                  "uiWidget": "pagePicker",
                  "editable": false
                }
              }
            },
            "uiLabel": "Navigation Links",
            "uiWidget": "repeater"
          }
        }
      },
      "dataType": "object",
      "enabled": true,
      "data": {
        "logoText": "CHAMAGE",
        "links": [
          {
            "label": "Home",
            "href": "/"
          },
          {
            "label": "Tour",
            "href": "/#tour360"
          },
          {
            "label": "Amenities",
            "href": "/#amenities"
          }
        ]
      }
    },
    {
      "id": "hero",
      "name": "Hero Section",
      "description": "Full-height hero with carousel, side thumbnails, and CTA.",
      "required": true,
      "imageSlots": [
        "backgroundImage",
        "src"
      ],
      "schema": {
        "type": "object",
        "required": [
          "headline",
          "subtext"
        ],
        "properties": {
          "overline": {
            "type": "string",
            "uiLabel": "Overline Text",
            "uiOrder": 1,
            "uiSection": "content"
          },
          "headline": {
            "type": "string",
            "description": "Main hero headline",
            "uiLabel": "Headline",
            "uiOrder": 2,
            "uiSection": "content"
          },
          "subtext": {
            "type": "string",
            "description": "Supporting text below headline",
            "uiLabel": "Subtext",
            "uiOrder": 3,
            "uiSection": "content"
          },
          "ctaText": {
            "type": "string",
            "uiLabel": "Button Text",
            "uiOrder": 4,
            "uiSection": "content"
          },
          "heroType": {
            "type": "string",
            "uiLabel": "Media Type",
            "uiWidget": "select",
            "options": [
              { "value": "image", "label": "Single Image" },
              { "value": "carousel", "label": "Carousel" },
              { "value": "video", "label": "Video" }
            ],
            "uiOrder": 10,
            "uiSection": "media"
          },
          "backgroundImage": {
            "type": "string",
            "description": "Hero background image (single image mode)",
            "uiLabel": "Background Image",
            "uiWidget": "imageUpload",
            "uiShowWhen": {
              "sibling": "heroType",
              "value": "image"
            }
          },
          "images": {
            "type": "array",
            "uiLabel": "Carousel Images",
            "uiWidget": "repeater",
            "constraints": {
              "minItems": 2,
              "maxItems": 10,
              "canAdd": true,
              "canRemove": true
            },
            "items": {
              "type": "object",
              "properties": {
                "src": {
                  "type": "string",
                  "uiLabel": "Image",
                  "uiWidget": "imageUpload"
                },
                "alt": {
                  "type": "string",
                  "uiLabel": "Alt Text"
                }
              }
            },
            "uiShowWhen": {
              "sibling": "heroType",
              "value": "carousel"
            }
          },
          "heroVideo": {
            "type": "string",
            "uiLabel": "Background Video",
            "uiWidget": "fileUpload",
            "uiAccept": "video/*",
            "uiShowWhen": {
              "sibling": "heroType",
              "value": "video"
            }
          },
          "videoAutoplay": {
            "type": "boolean",
            "uiLabel": "Autoplay Video",
            "uiShowWhen": {
              "sibling": "heroType",
              "value": "video"
            }
          },
          "videoMuted": {
            "type": "boolean",
            "uiLabel": "Mute Video",
            "uiShowWhen": {
              "sibling": "heroType",
              "value": "video"
            }
          },
          "mobileLayout": {
            "type": "string",
            "uiLabel": "Mobile Layout",
            "uiWidget": "select",
            "uiSection": "layout",
            "options": [
              { "value": "fullscreen", "label": "Full Screen" },
              { "value": "portrait", "label": "Portrait (3:4)" },
              { "value": "square", "label": "Square (1:1)" },
              { "value": "auto", "label": "Auto (Content Height)" }
            ]
          },
          "overlayEnabled": {
            "type": "boolean",
            "uiLabel": "Enable Overlay",
            "description": "Dark overlay on hero background for text readability",
            "uiSection": "layout"
          }
        }
      },
      "styleControls": {
        "fields": {
          "overline": [
            {
              "type": "slider",
              "property": "letterSpacing",
              "label": "Letter Spacing",
              "min": 0,
              "max": 0.5,
              "step": 0.05,
              "unit": "em",
              "default": "0.5em"
            },
            {
              "type": "colorGrid",
              "property": "color",
              "label": "Color",
              "presets": [
                {
                  "value": "#c9a96e",
                  "label": "Gold"
                },
                {
                  "value": "#ffffff",
                  "label": "White"
                },
                {
                  "value": "#a8a29e",
                  "label": "Muted"
                }
              ],
              "default": "#c9a96e"
            }
          ],
          "headline": [
            {
              "type": "slider",
              "property": "fontSize",
              "label": "Size",
              "responsive": true,
              "min": 2,
              "max": 7,
              "step": 0.5,
              "unit": "rem",
              "default": "4rem"
            },
            {
              "type": "buttonGroup",
              "property": "fontWeight",
              "label": "Weight",
              "options": [
                {
                  "value": "300",
                  "label": "Light"
                },
                {
                  "value": "400",
                  "label": "Regular"
                },
                {
                  "value": "600",
                  "label": "Semi"
                }
              ],
              "default": "300"
            },
            {
              "type": "colorGrid",
              "property": "color",
              "label": "Color",
              "presets": [
                {
                  "value": "#ffffff",
                  "label": "White"
                },
                {
                  "value": "#e7e5e4",
                  "label": "Light"
                },
                {
                  "value": "#c9a96e",
                  "label": "Gold"
                }
              ],
              "default": "#ffffff"
            }
          ],
          "subtext": [
            {
              "type": "slider",
              "property": "fontSize",
              "label": "Size",
              "responsive": true,
              "min": 0.75,
              "max": 1.5,
              "step": 0.125,
              "unit": "rem",
              "default": "0.875rem"
            },
            {
              "type": "colorGrid",
              "property": "color",
              "label": "Color",
              "presets": [
                {
                  "value": "rgba(255,255,255,0.5)",
                  "label": "Muted White"
                },
                {
                  "value": "#a8a29e",
                  "label": "Stone"
                },
                {
                  "value": "#ffffff",
                  "label": "White"
                }
              ],
              "default": "rgba(255,255,255,0.5)"
            }
          ],
          "ctaText": [
            {
              "type": "slider",
              "property": "letterSpacing",
              "label": "Letter Spacing",
              "min": 0,
              "max": 0.5,
              "step": 0.05,
              "unit": "em",
              "default": "0.3em"
            }
          ]
        }
      },
      "dataType": "object",
      "enabled": true,
      "data": {
        "overline": "Luxury Residences",
        "headline": "Chamage",
        "subtext": "Where architectural mastery meets uncompromising luxury. A singular residence designed for those who accept nothing less than perfection.",
        "heroType": "carousel",
        "backgroundImage": "defaults/default-hero.jpg",
        "images": [
          {
            "src": "defaults/default-hero.jpg",
            "alt": "Luxury residence exterior"
          },
          {
            "src": "defaults/default-secondary.jpg",
            "alt": "Interior living space"
          },
          {
            "src": "defaults/default-hero.jpg",
            "alt": "Architectural detail"
          }
        ],
        "ctaText": "Contact Us",
        "mobileLayout": "fullscreen",
        "overlayEnabled": true
      }
    },
    {
      "id": "tour360",
      "name": "360\u00b0 Virtual Tour",
      "description": "Interactive 360\u00b0 tour with iframe, image, or video.",
      "required": false,
      "imageSlots": [
        "tourImage"
      ],
      "schema": {
        "type": "object",
        "required": [
          "headline",
          "subtext",
          "tourType"
        ],
        "properties": {
          "headline": {
            "type": "string",
            "uiLabel": "Headline",
            "uiOrder": 1,
            "uiSection": "content"
          },
          "subtext": {
            "type": "string",
            "uiLabel": "Subtext",
            "uiOrder": 2,
            "uiSection": "content"
          },
          "tourType": {
            "type": "string",
            "uiLabel": "Tour Type",
            "uiWidget": "select",
            "options": [
              {
                "value": "iframe",
                "label": "3D Embed (iframe)"
              },
              {
                "value": "image",
                "label": "Panoramic Image"
              },
              {
                "value": "video",
                "label": "Video"
              }
            ],
            "uiOrder": 10,
            "uiSection": "media"
          },
          "tourUrl": {
            "type": "string",
            "uiLabel": "3D Embed URL",
