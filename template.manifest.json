            }
          },
          "tourImage": {
            "type": "string",
            "uiLabel": "Panoramic Image",
            "uiWidget": "imageUpload",
            "uiShowWhen": {
              "sibling": "tourType",
              "value": "image"
            }
          },
          "tourVideo": {
            "type": "string",
            "uiLabel": "Video URL",
            "uiWidget": "fileUpload",
            "uiAccept": "video/*",
            "uiShowWhen": {
              "sibling": "tourType",
              "value": "video"
            }
          },
          "videoAutoplay": {
            "type": "boolean",
            "uiLabel": "Autoplay Video",
            "uiShowWhen": {
              "sibling": "tourType",
              "value": "video"
            }
          },
          "videoMuted": {
            "type": "boolean",
            "uiLabel": "Mute Video",
            "uiShowWhen": {
              "sibling": "tourType",
              "value": "video"
            }
          }
        }
      },
      "styleControls": {
        "fields": {
          "headline": [
            {
              "type": "slider",
              "property": "fontSize",
              "responsive": true,
              "label": "Size",
              "min": 2,
              "max": 5,
              "step": 0.25,
              "unit": "rem",
              "default": "3rem"
            },
            {
              "type": "buttonGroup",
              "property": "fontWeight",
              "label": "Weight",
              "options": [
                {
                  "value": "300",
                  "label": "Light"
                },
                {
                  "value": "400",
                  "label": "Regular"
                },
                {
                  "value": "600",
                  "label": "Semi"
                }
              ],
              "default": "300"
            }
          ],
          "subtext": [
            {
              "type": "slider",
              "property": "fontSize",
              "responsive": true,
              "label": "Size",
              "min": 0.75,
              "max": 1.25,
              "step": 0.125,
              "unit": "rem",
              "default": "0.875rem"
            }
          ]
        }
      },
      "dataType": "object",
      "enabled": true,
      "data": {
        "headline": "Experience Every Corner",
        "subtext": "Navigate through the residence with our immersive 360\u00b0 virtual tour. Explore the spaces, the details, and the craftsmanship from the comfort of your screen.",
        "tourType": "video",
        "tourUrl": "",
        "tourImage": "defaults/default-hero.jpg",
        "tourVideo": "defaults/demo-video.mp4",
        "videoAutoplay": false,
        "videoMuted": true
      }
    },
